@using ElectronicsShop.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-lg-center gap-lg-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link user-chip"><i class="fa-regular fa-user me-1"></i>@User.Identity?.Name</span>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item"><a class="btn btn-sm btn-outline-light rounded-pill px-3" asp-area="Identity" asp-page="/Account/Register">Register</a></li>
    <li class="nav-item"><a class="btn btn-sm btn-light rounded-pill px-3" asp-area="Identity" asp-page="/Account/Login">Login</a></li>
}
</ul>
