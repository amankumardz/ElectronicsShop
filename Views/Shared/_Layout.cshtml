<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Electronics Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWix+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkR4j8iMGYxJv0QnYgQ8K/uexq2jc2iN1xwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom app-navbar sticky-top">
        <div class="container py-2">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="brand-icon"><i class="fa-solid fa-bolt"></i></span>
                Electronics Shop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Products" asp-action="Index"><i class="fa-solid fa-box-open me-1"></i>Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Repairs" asp-action="Create"><i class="fa-solid fa-screwdriver-wrench me-1"></i>Repairs</a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-chart-line me-1"></i>Dashboard</a>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<div class="container app-content py-4 py-lg-5">
    <main role="main" class="fade-in">
        @RenderBody()
    </main>
</div>

<footer class="app-footer mt-5">
    <div class="container py-4">
        <div class="row g-4">
            <div class="col-md-5">
                <h5 class="mb-3">Electronics Shop</h5>
                <p class="mb-2 text-muted">Your one-stop destination for electronics shopping and trusted repair services.</p>
                <p class="mb-0 text-muted"><i class="fa-solid fa-phone me-2"></i>+1 (555) 120-5678</p>
                <p class="mb-0 text-muted"><i class="fa-solid fa-envelope me-2"></i>support@electronicsshop.com</p>
            </div>
            <div class="col-md-3">
                <h6 class="mb-3">Quick Links</h6>
                <ul class="list-unstyled footer-links mb-0">
                    <li><a asp-controller="Products" asp-action="Index">Browse Products</a></li>
                    <li><a asp-controller="Repairs" asp-action="Create">Book Repair</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="mb-3">Follow Us</h6>
                <div class="d-flex gap-2 social-links">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
