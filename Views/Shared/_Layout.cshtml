<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Electronics Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg app-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="brand-icon"><i class="fa-solid fa-bolt-lightning"></i></span>
                <span class="brand-text">Electronics Shop</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index"><i class="fa-solid fa-store me-1"></i>Products</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Repairs" asp-action="Create"><i class="fa-solid fa-screwdriver-wrench me-1"></i>Repairs</a></li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-chart-line me-1"></i>Dashboard</a></li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<div class="page-shell">
    <main role="main" class="container app-main fade-in py-4 py-lg-5">
        @RenderBody()
    </main>

    <footer class="app-footer mt-auto">
        <div class="container py-4">
            <div class="row g-4 align-items-start">
                <div class="col-lg-4">
                    <h5 class="footer-title">Electronics Shop</h5>
                    <p class="text-muted mb-0">Your one-stop destination for quality electronics and trusted repair services.</p>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <h6 class="footer-subtitle">Quick Links</h6>
                    <ul class="list-unstyled footer-links mb-0">
                        <li><a asp-controller="Products" asp-action="Index">Browse Products</a></li>
                        <li><a asp-controller="Repairs" asp-action="Create">Book Repair</a></li>
                        <li><a asp-controller="Repairs" asp-action="MyRepairs">My Repairs</a></li>
                    </ul>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <h6 class="footer-subtitle">Contact</h6>
                    <p class="mb-1"><i class="fa-solid fa-phone me-2"></i>+1 (555) 428-9900</p>
                    <p class="mb-2"><i class="fa-solid fa-envelope me-2"></i>support@electronicsshop.com</p>
                    <div class="social-icons d-flex gap-2">
                        <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
