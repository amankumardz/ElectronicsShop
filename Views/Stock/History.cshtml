@model IEnumerable<ElectronicsShop.Models.StockHistoryLog>
<h1 class="section-title mb-3">Stock History</h1>
<table class="table table-modern"><thead><tr><th>Product</th><th>Type</th><th>Qty</th><th>Prev</th><th>New</th><th>Invoice</th><th>Reason</th><th>Admin</th><th>Date</th></tr></thead><tbody>
@foreach(var h in Model){<tr><td>@h.Product?.Name</td><td>@h.ChangeType</td><td>@h.QuantityChanged</td><td>@h.PreviousStock</td><td>@h.NewStock</td><td>@h.InvoiceReference</td><td>@h.ReasonNote</td><td>@h.AdminUser?.Email</td><td>@h.CreatedAt</td></tr>}
</tbody></table>
