@model IEnumerable<ElectronicsShop.Models.Product>
@using ElectronicsShop.Models.Enums
<h1 class="section-title mb-3">Stock Management</h1>
<p><a class="btn btn-primary" asp-action="Add">Add Manual Stock</a> <a class="btn btn-outline-primary" asp-action="UploadInvoice">Upload Invoice</a> <a class="btn btn-outline-dark" asp-action="History">History</a></p>
<table class="table table-modern"><thead><tr><th>Product</th><th>Qty</th><th>Status</th><th>Action</th></tr></thead><tbody>
@foreach (var p in Model){<tr><td>@p.Name</td><td>@p.StockQuantity @p.Unit</td><td>@p.StockStatus</td><td>
<form asp-action="Adjust" method="post" class="d-flex gap-2"><input type="hidden" name="ProductId" value="@p.Id" />
<select name="ChangeType" class="form-select form-select-sm"><option value="Reduce">REDUCE</option><option value="Damage">DAMAGE</option><option value="Consumed">CONSUMED</option><option value="SoldManually">SOLD</option><option value="Returned">RETURNED</option><option value="OutOfStock">OUT_OF_STOCK</option></select>
<input name="Quantity" class="form-control form-control-sm" placeholder="Qty" />
<input name="Reason" class="form-control form-control-sm" placeholder="Reason" />
<button class="btn btn-sm btn-danger">Apply</button></form></td></tr>}
</tbody></table>
