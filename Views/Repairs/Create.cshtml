@model ElectronicsShop.Models.RepairRequest
@{
    ViewData["Title"] = Model.IsWalkIn ? "Walk-In Entry" : "Book Repair";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="glass-panel p-4 p-md-5">
            <h1 class="section-title mb-2">@(Model.IsWalkIn ? "Walk-In Repair Entry" : "Book a Repair")</h1>
            <p class="text-muted mb-4">Fill in the details below and our technician team will start processing your request quickly.</p>

            <form asp-action="@(Model.IsWalkIn ? "WalkInCreate" : "Create")" method="post" class="d-grid gap-3" data-loading-form>
                <div>
                    <label asp-for="CustomerName" class="form-label"><i class="fa-regular fa-user me-2"></i>Customer Name</label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Enter full name" />
                </div>
                <div>
                    <label asp-for="CustomerPhone" class="form-label"><i class="fa-solid fa-phone me-2"></i>Phone Number</label>
                    <input asp-for="CustomerPhone" class="form-control" placeholder="Enter contact number" />
                </div>
                <div>
                    <label asp-for="DeviceName" class="form-label"><i class="fa-solid fa-mobile-screen-button me-2"></i>Device Name</label>
                    <input asp-for="DeviceName" class="form-control" placeholder="e.g., Samsung TV" />
                </div>
                <div>
                    <label asp-for="IssueDescription" class="form-label"><i class="fa-solid fa-circle-exclamation me-2"></i>Issue Description</label>
                    <textarea asp-for="IssueDescription" class="form-control" rows="4" placeholder="Describe the issue..."></textarea>
                </div>

                <div class="d-flex gap-2 pt-2">
                    <button class="btn btn-primary" type="submit" data-loading-btn>
                        <span class="default-text"><i class="fa-solid fa-paper-plane me-2"></i>Submit Request</span>
                        <span class="loading-text d-none"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Submitting...</span>
                    </button>
                    <a class="btn btn-light border" asp-controller="Home" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
