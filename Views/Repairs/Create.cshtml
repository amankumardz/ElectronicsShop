@model ElectronicsShop.Models.RepairRequest
@{
    ViewData["Title"] = Model.IsWalkIn ? "Walk-In Entry" : "Book Repair";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <section class="form-shell p-4 p-lg-5">
            <h1 class="h3 fw-bold mb-2">@(Model.IsWalkIn ? "Walk-In Repair Entry" : "Book a Repair")</h1>
            <p class="text-muted mb-4">Fill in the details and our technicians will get in touch quickly.</p>

            <form asp-action="@(Model.IsWalkIn ? "WalkInCreate" : "Create")" method="post" class="repair-form" data-loading-form>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label"><i class="fa-regular fa-user me-2"></i>Customer Name</label>
                        <input asp-for="CustomerName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CustomerPhone" class="form-label"><i class="fa-solid fa-phone me-2"></i>Phone</label>
                        <input asp-for="CustomerPhone" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="DeviceName" class="form-label"><i class="fa-solid fa-microchip me-2"></i>Device Name</label>
                        <input asp-for="DeviceName" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="IssueDescription" class="form-label"><i class="fa-regular fa-rectangle-list me-2"></i>Issue Description</label>
                        <textarea asp-for="IssueDescription" rows="5" class="form-control"></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button class="btn btn-primary px-4" type="submit" data-loading-button>
                        <span class="default-label"><i class="fa-solid fa-paper-plane me-2"></i>Submit Request</span>
                        <span class="loading-label d-none"><span class="spinner-border spinner-border-sm me-2"></span>Submitting...</span>
                    </button>
                    @if (Model.IsWalkIn)
                    {
                        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                    }
                </div>
            </form>
        </section>
    </div>
</div>
