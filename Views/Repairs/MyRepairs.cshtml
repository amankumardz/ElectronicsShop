@model IEnumerable<ElectronicsShop.Models.RepairRequest>
@{
    ViewData["Title"] = "My Repairs";
}

<h1 class="h3 fw-bold mb-4">My Repair Requests</h1>

<div class="row g-3">
@foreach (var r in Model)
{
    var statusClass = r.Status.ToString() switch
    {
        "Pending" => "status-pending",
        "InProgress" => "status-progress",
        "Completed" => "status-complete",
        _ => "text-bg-secondary"
    };

    <div class="col-md-6">
        <article class="timeline-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                <div>
                    <h5 class="mb-1">@r.DeviceName</h5>
                    <p class="text-muted mb-0 small">Ticket #@r.Id</p>
                </div>
                <span class="badge @statusClass">@r.Status</span>
            </div>
            <p class="mb-2"><strong>Estimated Cost:</strong> @(r.EstimatedCost?.ToString("C") ?? "-")</p>
            <p class="text-muted small mb-0"><i class="fa-regular fa-clock me-1"></i>Last Updated: @(r.UpdatedAtUtc?.ToString("u") ?? r.CreatedAtUtc.ToString("u"))</p>
        </article>
    </div>
}
</div>
