@model IEnumerable<ElectronicsShop.Models.RepairRequest>
@{
    ViewData["Title"] = "My Repairs";
}

<h1 class="section-title mb-4">My Repair Requests</h1>

<div class="row g-3">
    @foreach (var r in Model)
    {
        var statusClass = r.Status.ToString() switch
        {
            "Pending" => "badge-status-pending",
            "InProgress" => "badge-status-progress",
            _ => "badge-status-completed"
        };

        <div class="col-md-6 col-xl-4">
            <article class="glass-panel p-3 h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">@r.DeviceName</h5>
                    <span class="badge @statusClass">@r.Status</span>
                </div>
                <p class="text-muted mb-2">Ticket #@r.Id</p>
                <div class="small text-muted d-grid gap-1">
                    <span><i class="fa-regular fa-clock me-2"></i>Updated: @(r.UpdatedAtUtc?.ToLocalTime().ToString("g") ?? r.CreatedAtUtc.ToLocalTime().ToString("g"))</span>
                    <span><i class="fa-solid fa-dollar-sign me-2"></i>Estimated Cost: @(r.EstimatedCost?.ToString("C") ?? "Pending estimate")</span>
                </div>
            </article>
        </div>
    }
</div>
