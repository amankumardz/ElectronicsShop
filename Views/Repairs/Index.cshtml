@model IEnumerable<ElectronicsShop.Models.RepairRequest>
@{
    ViewData["Title"] = "Manage Repairs";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h1 class="h3 fw-bold mb-0">Repair Management</h1>
    <a class="btn btn-primary" asp-action="WalkInCreate"><i class="fa-solid fa-user-plus me-2"></i>Add Walk-In Entry</a>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0 modern-table">
            <thead>
                <tr><th>ID</th><th>Customer</th><th>Device</th><th>Status</th><th>Cost</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                var statusClass = r.Status.ToString() switch
                {
                    "Pending" => "status-pending",
                    "InProgress" => "status-progress",
                    "Completed" => "status-complete",
                    _ => "text-bg-secondary"
                };

                <tr>
                    <td>#@r.Id</td>
                    <td>@r.CustomerName</td>
                    <td>@r.DeviceName</td>
                    <td><span class="badge @statusClass">@r.Status</span></td>
                    <td>@(r.EstimatedCost?.ToString("C") ?? "-")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="UpdateStatus" asp-route-id="@r.Id">
                            <i class="fa-solid fa-pen-to-square me-1"></i>Update
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
