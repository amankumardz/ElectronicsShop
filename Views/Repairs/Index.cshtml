@model IEnumerable<ElectronicsShop.Models.RepairRequest>
@{
    ViewData["Title"] = "Manage Repairs";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="section-title mb-0">Repair Management</h1>
    <a class="btn btn-primary" asp-action="WalkInCreate"><i class="fa-solid fa-plus me-2"></i>Add Walk-In Entry</a>
</div>

<div class="glass-panel p-3 p-md-4">
    <div class="table-responsive">
        <table class="table align-middle table-modern mb-0">
            <thead>
            <tr><th>ID</th><th>Customer</th><th>Device</th><th>Status</th><th>Cost</th><th>Action</th></tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                var statusClass = r.Status.ToString() switch
                {
                    "Pending" => "badge-status-pending",
                    "InProgress" => "badge-status-progress",
                    _ => "badge-status-completed"
                };

                <tr>
                    <td>#@r.Id</td>
                    <td>@r.CustomerName</td>
                    <td>@r.DeviceName</td>
                    <td><span class="badge @statusClass">@r.Status</span></td>
                    <td>@(r.EstimatedCost?.ToString("C") ?? "-")</td>
                    <td>
                        <a asp-action="UpdateStatus" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square me-1"></i>Update</a>
                        <button class="btn btn-sm btn-light border" data-bs-toggle="modal" data-bs-target="#repairModal-@r.Id"><i class="fa-solid fa-eye me-1"></i>View</button>

                        <div class="modal fade" id="repairModal-@r.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Repair #@r.Id</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p class="mb-2"><strong>Customer:</strong> @r.CustomerName</p>
                                        <p class="mb-2"><strong>Phone:</strong> @r.CustomerPhone</p>
                                        <p class="mb-2"><strong>Device:</strong> @r.DeviceName</p>
                                        <p class="mb-0"><strong>Issue:</strong> @r.IssueDescription</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
