@{
    ViewData["Title"] = "Home";
}

<section class="hero-section rounded-4 overflow-hidden mb-5">
    <div class="hero-overlay p-4 p-md-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge text-bg-light text-primary mb-3">Premium Electronics + Fast Repairs</span>
                <h1 class="display-5 fw-bold text-white mb-3">Your Trusted Electronics &amp; Repair Shop</h1>
                <p class="lead text-white-50 mb-4">Discover top-quality appliances, DJ equipment, wiring tools, and professional repair services managed in one seamless platform.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-lg px-4" asp-controller="Products" asp-action="Index"><i class="fa-solid fa-bag-shopping me-2"></i>Browse Products</a>
                    <a class="btn btn-outline-light btn-lg px-4" asp-controller="Repairs" asp-action="Create"><i class="fa-solid fa-wrench me-2"></i>Book Repair</a>
                </div>
            </div>
            <div class="col-lg-5 text-center">
                <img class="img-fluid hero-image" src="https://images.unsplash.com/photo-1550009158-9ebf69173e03?auto=format&fit=crop&w=900&q=80" alt="Electronics devices" />
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title mb-0">Shop by Category</h2>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <article class="feature-card h-100">
                <img src="https://images.unsplash.com/photo-1585155770447-2f66e2a397b5?auto=format&fit=crop&w=900&q=80" class="card-img-top" alt="Home Appliances">
                <div class="p-3">
                    <h5>Home Appliances</h5>
                    <p class="text-muted mb-0">Reliable, efficient appliances for modern homes.</p>
                </div>
            </article>
        </div>
        <div class="col-md-4">
            <article class="feature-card h-100">
                <img src="https://images.unsplash.com/photo-1558537348-c0f8e733989d?auto=format&fit=crop&w=900&q=80" class="card-img-top" alt="Wiring Items">
                <div class="p-3">
                    <h5>Wiring Items</h5>
                    <p class="text-muted mb-0">Safe and durable wiring products for every setup.</p>
                </div>
            </article>
        </div>
        <div class="col-md-4">
            <article class="feature-card h-100">
                <img src="https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?auto=format&fit=crop&w=900&q=80" class="card-img-top" alt="DJ Equipment">
                <div class="p-3">
                    <h5>DJ Equipment</h5>
                    <p class="text-muted mb-0">High-performance speakers, mixers, and lighting gear.</p>
                </div>
            </article>
        </div>
    </div>
</section>

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title mb-0">Featured Products</h2>
        <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="Index">View all</a>
    </div>
    <div class="row g-4">
        @for (var i = 0; i < 4; i++)
        {
            <div class="col-sm-6 col-xl-3">
                <div class="product-tile h-100">
                    <img src="https://images.unsplash.com/photo-1518444065439-e933c06ce9cd?auto=format&fit=crop&w=700&q=80" alt="Featured electronic" />
                    <div class="p-3">
                        <h6 class="mb-1">Top Electronic Pick</h6>
                        <p class="text-muted small mb-2">Professional-grade product for daily use.</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">$299.99</span>
                            <a class="btn btn-sm btn-primary" asp-controller="Products" asp-action="Index">View</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
