@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<div class="row g-4 align-items-start">
    <div class="col-lg-6">
        <div class="glass-panel p-3">
            <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1100&q=80" alt="@Model.Name" class="img-fluid rounded-4 w-100 product-detail-image" />
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-panel p-4 h-100">
            <span class="badge rounded-pill text-bg-info-subtle text-info-emphasis mb-2">@Model.Category?.Name</span>
            <h1 class="section-title mb-2">@Model.Name</h1>
            <p class="text-muted mb-3">@Model.Description</p>
            <h3 class="text-primary fw-bold mb-4">@Model.Price.ToString("C")</h3>

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" href="#"><i class="fa-regular fa-heart me-2"></i>Mark as Interested</a>
                <a class="btn btn-outline-primary" asp-controller="Repairs" asp-action="Create"><i class="fa-solid fa-screwdriver-wrench me-2"></i>Book Repair</a>
                <a class="btn btn-light border" asp-action="Index">Back to Products</a>
            </div>
        </div>
    </div>
</div>
