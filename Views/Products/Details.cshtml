@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Product Details";
    var category = Model.Category?.Name ?? "General";
    var image = category.Contains("dj", StringComparison.OrdinalIgnoreCase)
        ? "https://images.unsplash.com/photo-1571266028243-d220c9f58c59?auto=format&fit=crop&w=1200&q=80"
        : category.Contains("wiring", StringComparison.OrdinalIgnoreCase)
            ? "https://images.unsplash.com/photo-1621905251918-48416bd8575a?auto=format&fit=crop&w=1200&q=80"
            : "https://images.unsplash.com/photo-1550009158-9ebf69173e03?auto=format&fit=crop&w=1200&q=80";
}

<div class="card app-card p-4 p-lg-5">
    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <img src="@image" alt="@Model.Name" class="img-fluid rounded-4 shadow-sm product-detail-image" />
        </div>
        <div class="col-lg-6">
            <span class="badge text-bg-light border mb-2">@category</span>
            <h2 class="mb-3">@Model.Name</h2>
            <p class="text-muted mb-4">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description available for this product." : Model.Description)</p>
            <h3 class="fw-bold mb-4">@Model.Price.ToString("C")</h3>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-controller="Repairs" asp-action="Create"><i class="fa-solid fa-screwdriver-wrench me-2"></i>Book Repair</a>
                <button class="btn btn-outline-primary" type="button"><i class="fa-regular fa-heart me-2"></i>Mark as Interested</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Back to Products</a>
            </div>
        </div>
    </div>
</div>
