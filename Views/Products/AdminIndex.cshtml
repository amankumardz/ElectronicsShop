@model IEnumerable<ElectronicsShop.Models.Product>
<h2>Manage Products</h2>
<a class="btn btn-primary mb-3" asp-action="Create">Add Product</a>
<table class="table table-striped">
    <thead><tr><th>Name</th><th>Category</th><th>Price</th><th></th></tr></thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td><td>@p.Category?.Name</td><td>@p.Price.ToString("C")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@p.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@p.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
