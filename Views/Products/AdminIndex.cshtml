@model IEnumerable<ElectronicsShop.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="section-title mb-0">Product Management</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="fa-solid fa-plus me-2"></i>Add Product</a>
</div>

<div class="glass-panel p-3 p-md-4">
    <div class="table-responsive">
        <table class="table align-middle table-modern mb-0">
            <thead><tr><th>Name</th><th>Category</th><th>Price</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-semibold">@p.Name</td>
                    <td><span class="badge rounded-pill text-bg-info-subtle text-info-emphasis">@p.Category?.Name</span></td>
                    <td>@p.Price.ToString("C")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen-to-square"></i></a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
