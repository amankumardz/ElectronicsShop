@model IEnumerable<ElectronicsShop.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h1 class="h3 fw-bold mb-0">Manage Products</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="fa-solid fa-plus me-2"></i>Add Product</a>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0 modern-table">
            <thead><tr><th>Name</th><th>Category</th><th>Price</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Category?.Name</td>
                    <td>@p.Price.ToString("C")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id"><i class="fa-solid fa-pen me-1"></i>Edit</a>
                        <a class="btn btn-sm btn-outline-danger ms-1" asp-action="Delete" asp-route-id="@p.Id"><i class="fa-solid fa-trash me-1"></i>Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
