@model IEnumerable<ElectronicsShop.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1">Manage Products</h2>
        <p class="text-muted mb-0">Add and maintain your store inventory.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="fa-solid fa-plus me-2"></i>Add Product</a>
</div>

<div class="card app-card p-3 p-lg-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-semibold">@p.Name</td>
                    <td><span class="badge text-bg-light border">@p.Category?.Name</span></td>
                    <td>@p.Price.ToString("C")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id"><i class="fa-regular fa-pen-to-square"></i></a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@p.Id"><i class="fa-regular fa-trash-can"></i></a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
