@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="glass-panel p-4 text-center">
            <h1 class="section-title mb-3">Delete Product</h1>
            <p class="text-muted">Are you sure you want to delete <strong>@Model.Name</strong>?</p>
            <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash me-2"></i>Delete</button>
                <a asp-action="AdminIndex" class="btn btn-light border">Cancel</a>
            </form>
        </div>
    </div>
</div>
