@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card app-card p-4 p-lg-5 text-center">
            <h2 class="mb-3">Delete Product</h2>
            <p class="text-muted mb-4">Are you sure you want to delete <strong>@Model.Name</strong>? This action cannot be undone.</p>
            <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger"><i class="fa-regular fa-trash-can me-2"></i>Delete</button>
                <a asp-action="AdminIndex" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
