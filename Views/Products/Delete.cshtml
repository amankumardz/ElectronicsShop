@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-shell p-4 p-lg-5 text-center">
            <h1 class="h3 fw-bold mb-3">Delete Product</h1>
            <p class="mb-4">Are you sure you want to delete <strong>@Model.Name</strong>?</p>
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="AdminIndex" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
