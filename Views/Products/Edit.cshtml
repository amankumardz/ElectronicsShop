@model ElectronicsShop.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="glass-panel p-4">
            <h1 class="section-title mb-3">Edit Product</h1>
            <form asp-action="Edit" method="post" class="d-grid gap-3">
                <input type="hidden" asp-for="Id" />
                <div><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
                <div><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="4"></textarea></div>
                <div><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /></div>
                <div><label asp-for="CategoryId" class="form-label">Category</label><select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select"></select></div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Update</button>
                    <a class="btn btn-light border" asp-action="AdminIndex">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
