# Google OAuth configuration
# Use the same values in your local user secrets or environment for production.
AUTHENTICATION__GOOGLE__CLIENTID=your-google-client-id
AUTHENTICATION__GOOGLE__CLIENTSECRET=your-google-client-secret
AUTHENTICATION__GOOGLE__CALLBACKPATH=/signin-google

# Optional app URLs if you need them for deployment scripts
FRONTEND_URL=https://localhost:5001
API_URL=https://localhost:5001
